{
  "name": "search-files-tools",
  "version": "0.1.0",
  "description": "OpenClaw plugin for searching and globbing files",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "grep",
    "glob",
    "files"
  ],
  "homepage": "https://github.com/openclaw/search-files-tools#readme",
  "bugs": {
    "url": "https://github.com/openclaw/search-files-tools/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openclaw/search-files-tools.git"
  },
  "files": [
    "index.ts",
    "src",
    "types",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "oxlint": "^0.15.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
